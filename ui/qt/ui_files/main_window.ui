  <property name="styleSheet">
   <string notr="true">
QMainWindow, QWidget#main_widget {
    background-color: #0f1117;
    color: #e0e0e0;
}
QFrame#ticker_bar {
    background-color: #161b27;
    border-bottom: 1px solid #2a3040;
}
QLabel#ticker_label {
    color: #a0aabb;
    font-size: 11px;
    padding: 2px 6px;
}
QLabel#gold_label {
    color: #f5c842;
    font-weight: bold;
    font-size: 12px;
    padding: 2px 8px;
}
QTabWidget::pane {
    border: 1px solid #2a3040;
    background-color: #0f1117;
}
QTabBar::tab {
    background-color: #161b27;
    color: #7a8ba0;
    padding: 8px 22px;
    font-size: 13px;
    border: 1px solid #2a3040;
    border-bottom: none;
    margin-right: 2px;
}
QTabBar::tab:selected {
    background-color: #1e2535;
    color: #e0e0e0;
    border-top: 2px solid #4a8cff;
}
QTabBar::tab:hover {
    background-color: #1a2030;
    color: #c0c8d8;
}
QLineEdit#search_input_korea,
QLineEdit#search_input_japan,
QLineEdit#search_input_us,
QLineEdit#search_input_europe {
    background-color: #1a2030;
    color: #e0e0e0;
    border: 1px solid #2e3d56;
    border-radius: 6px;
    padding: 8px 12px;
    font-size: 14px;
    selection-background-color: #2d4a7a;
}
QLineEdit#search_input_korea:focus,
QLineEdit#search_input_japan:focus,
QLineEdit#search_input_us:focus,
QLineEdit#search_input_europe:focus {
    border: 1px solid #4a8cff;
}
QPushButton#search_btn_korea,
QPushButton#search_btn_japan,
QPushButton#search_btn_us,
QPushButton#search_btn_europe {
    background-color: #2d5aac;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 8px 20px;
    font-size: 13px;
    font-weight: bold;
}
QPushButton#search_btn_korea:hover,
QPushButton#search_btn_japan:hover,
QPushButton#search_btn_us:hover,
QPushButton#search_btn_europe:hover {
    background-color: #3568c4;
}
QPushButton#search_btn_korea:pressed,
QPushButton#search_btn_japan:pressed,
QPushButton#search_btn_us:pressed,
QPushButton#search_btn_europe:pressed {
    background-color: #1e4088;
}
QFrame#result_card_korea,
QFrame#result_card_japan,
QFrame#result_card_us,
QFrame#result_card_europe {
    background-color: #161b27;
    border: 1px solid #2a3040;
    border-radius: 10px;
    padding: 6px;
}
QLabel#res_name   { color: #a8b8cc; font-size: 12px; }
QLabel#res_ticker { color: #556070; font-size: 11px; }
QLabel#res_price  { color: #e8eef8; font-size: 28px; font-weight: bold; }
QLabel#res_change_pos { color: #3ddc84; font-size: 14px; font-weight: bold; }
QLabel#res_change_neg { color: #ff5f5f; font-size: 14px; font-weight: bold; }
QLabel#res_change_neu { color: #aaaaaa; font-size: 14px; }
QLabel#hint_label_korea,
QLabel#hint_label_japan,
QLabel#hint_label_us,
QLabel#hint_label_europe {
    color: #3a4a60; font-size: 11px; font-style: italic;
}
QLabel#status_label { color: #556070; font-size: 11px; }
QLabel#loading_label { color: #4a8cff; font-size: 13px; }
QLabel#error_label   { color: #ff5f5f; font-size: 13px; }
